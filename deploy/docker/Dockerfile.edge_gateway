FROM python:3.11-slim

WORKDIR /app

COPY services/edge_gateway/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

COPY common /app/common
COPY services /app/services

CMD ["python", "-m", "services.edge_gateway.app", "--config", "configs/edge_gateway.self_hosted.yaml"]
